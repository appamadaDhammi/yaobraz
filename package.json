{
  "name": "spinning-oort",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "kiosk": "concurrently --kill-others \"vite\" \"wait-on tcp:5173 && electron .\"",
    "postinstall": "node -e \"try{require('child_process').execSync('xattr -cr node_modules/electron/dist/Electron.app')}catch{}\""
  },
  "dependencies": {
    "planck": "^1.4.2",
    "qrcode.vue": "^3.8.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.1.2",
    "electron": "^40.6.1",
    "wait-on": "^8.0.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5"
  }
}
